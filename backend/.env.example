STOCK_AH_DB_URL=mysql+pymysql://root@127.0.0.1:3306/stock_ah_ai?charset=utf8mb4
TUSHARE_TOKEN=
TUSHARE_TOKEN_FILE=/Users/salty/codeProject/ai/doc/tushare-token.txt
TUSHARE_API_URL=https://tt.xiaodefa.cn
TUSHARE_REQUEST_INTERVAL_SECONDS=0.6
SYNC_SCHEDULER_ENABLED=true
SYNC_SCHEDULER_TIMEZONE=Asia/Shanghai
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY_FILE=/Users/salty/codeProject/ai/doc/deepseek-apikey.txt
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_DAILY_CALL_LIMIT=100
IMAGE_GEN_BASE_URL=https://api.86gamestore.com
IMAGE_GEN_API_KEY_FILE=/Users/salty/codeProject/ai/doc/86gamestore-image-apikey.txt
IMAGE_GEN_API_KEY=
IMAGE_GEN_MODEL=gpt-image-2
IMAGE_GEN_TIMEOUT_SECONDS=500
IMAGE_GEN_DAILY_LIMIT_DEFAULT=10
IMAGE_GEN_STORAGE_BACKEND=oss
IMAGE_GEN_STORAGE_DIR=/opt/stock-ah-premium-ai/data/generated-images
IMAGE_GEN_OSS_ENDPOINT=
IMAGE_GEN_OSS_BUCKET=
IMAGE_GEN_OSS_PREFIX=stock-ah-premium-ai/generated-images
IMAGE_GEN_OSS_ACCESS_KEY_ID=
IMAGE_GEN_OSS_ACCESS_KEY_ID_FILE=
IMAGE_GEN_OSS_ACCESS_KEY_SECRET=
IMAGE_GEN_OSS_ACCESS_KEY_SECRET_FILE=
IMAGE_GEN_OSS_SECURITY_TOKEN=
IMAGE_GEN_OSS_SECURITY_TOKEN_FILE=
IMAGE_GEN_OSS_SIGNED_URL_EXPIRES_SECONDS=86400
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY_FILE=/Users/salty/codeProject/ai/doc/qwen-apikey.txt
QWEN_API_KEY=
QWEN_QUESTION_ROUTER_MODEL=deepseek-v4-flash
# ---- Agent 问答引擎（Agent 化重构配置，阶段 1 起生效）----
AGENT_MODEL=deepseek-v4-pro
AGENT_MAX_ITERATIONS=8
AGENT_CONTEXT_BUDGET_CHARS=48000
CHAT_DAILY_ROUND_LIMIT=50
# ---- 博查联网搜索（key 文件优先，环境变量兜底；缺失时自动降级为无联网能力）----
BOCHA_BASE_URL=https://api.bochaai.com
BOCHA_API_KEY_FILE=/Users/salty/codeProject/ai/doc/博查-apikey.txt
BOCHA_API_KEY=
AGENT_WEB_SEARCH_DAILY_LIMIT=100
# ---- Python 沙箱（subprocess + 资源限制）----
AGENT_RUN_PYTHON_DAILY_LIMIT=100
PY_SANDBOX_WALL_TIMEOUT_SECONDS=20
PY_SANDBOX_CPU_SECONDS=10
PY_SANDBOX_MEMORY_MB=512
PY_SANDBOX_OUTPUT_MAX_CHARS=8000
# ---- 问答治理（阶段 5）----
# 流式问答同时活跃的后台 worker 上限；超限返回 503 繁忙提示，防止耗尽数据库连接池。
CHAT_STREAM_MAX_CONCURRENCY=8
# 获取并发名额的最长等待秒数，超时返回繁忙。
CHAT_STREAM_ACQUIRE_TIMEOUT_SECONDS=15
# llm_call_metric 保留天数；scripts/cleanup-llm-metrics.sh 删除更早记录，<=0 不清理。
LLM_METRIC_RETENTION_DAYS=90
APP_CORS_ORIGINS=http://localhost:5173
AUTH_SECRET_KEY=stock-ah-premium-local-secret
AUTH_TOKEN_EXPIRE_HOURS=168
AUTH_REMEMBER_LOGIN_EXPIRE_DAYS=30
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456
ALERT_SCHEDULER_ENABLED=true
ALERT_SCAN_SECONDS=1
ALERT_SCAN_HOURS=9-16
LIMIT_UP_PUSH_SCHEDULER_ENABLED=true
LIMIT_UP_PUSH_CHAIN_FOCUS_STOCK_LIMIT=20
LIMIT_UP_PUSH_HIGH_BOARD_FOCUS_STOCK_LIMIT=10
# 首板重点入选上限："少量精选"口径，过大会稀释精选定位并抬升筹码补数调用量
LIMIT_UP_PUSH_FIRST_BOARD_FOCUS_STOCK_LIMIT=5
LIMIT_UP_PUSH_CYQ_LOOKBACK_DAYS=20
LIMIT_UP_PUSH_STAGE_CACHE_ENABLED=true
# v3：最终合成阶段含首板重点个股小节；改回旧值会命中旧提示词时代的阶段缓存
LIMIT_UP_PUSH_FINAL_PROMPT_VERSION=limit-up-multi-stage-v3
# 推送内容模式：ADVICE=推送投资建议（默认）；REPORT=推送完整报告（严格回滚通道）
LIMIT_UP_PUSH_CONTENT_MODE=ADVICE
# PushPlus 渠道：建议生成失败时是否降级推送完整报告（默认开，保障早盘交付）
LIMIT_UP_PUSH_ADVICE_FALLBACK_TO_REPORT=true
# 雪球发布内容模式：独立于 PushPlus，两渠道受众不同允许分别回滚
XUEQIU_LIMIT_UP_CONTENT_MODE=ADVICE
# 雪球渠道建议失败降级开关：默认关——公开平台宁可当日不发，也不发与预期不符的整报
XUEQIU_LIMIT_UP_ADVICE_FALLBACK_TO_REPORT=false
NINE_TURN_PUSH_SCHEDULER_ENABLED=false
NINE_TURN_PUSH_POLL_HOURS=21-22
NINE_TURN_PUSH_POLL_MINUTES=10,20,30,40,50
NINE_TURN_PUSH_MODEL=deepseek-v4-pro
NINE_TURN_PUSH_PROMPT_VERSION=nine-turn-v1
PUSHPLUS_ENABLED=true
PUSHPLUS_TOKEN_FILE=/Users/salty/codeProject/ai/doc/pushplus.txt
PUSHPLUS_SECRET_KEY_FILE=/Users/salty/codeProject/ai/doc/pushplus.txt
PUSHPLUS_TEMPLATE=html
PUSHPLUS_CHANNEL=wechat
